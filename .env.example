# --- Optional free-tier API keys (leave blank to skip that provider) ---
# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=

# Get a free key at https://twelvedata.com/pricing (free tier: 800 req/day)
TWELVEDATA_API_KEY=

# StockerAPI / Kun Data (kun.pro) is a PAID product. No free tier exists.
# Only set these if you have purchased access.
STOCKERAPI_TOKEN=
STOCKERAPI_BASE_URL=https://api.kun.pro

# --- Backend ---
PORT=4000
REDIS_URL=redis://localhost:6379

# --- Telegram Bot (for Alarm push notifications) ---
TELEGRAM_BOT_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:4000
NEXT_PUBLIC_BACKEND_HTTP_URL=http://localhost:4000
