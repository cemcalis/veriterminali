# --- Optional free-tier API keys (leave blank to skip that provider) ---
# Get a free key at https://finnhub.io/register (no credit card required).
# Once set, market-hub.ts opens a genuine free real-time trade WebSocket
# (wss://ws.finnhub.io) for us_stock/etf symbols -- a real, legal upgrade
# that isn't subject to the IP-based blocking the unofficial TradingView
# socket can hit on shared cloud-hosting ranges (see tradingview-socket.ts).
FINNHUB_API_KEY=

# Get a free key at https://twelvedata.com/pricing. Sized here for the
# "Basic 8" plan specifically: 800 credits/day, 8 requests/min, 1 WS
# connection with 8 WS symbol credits -- twelvedata.provider.ts enforces
# all three limits itself (dual rate limiter + 20s quote cache), so it's
# safe to leave this set even under a tight quota. Priority: forex,
# commodities/metals, indices, then US stock/ETF fallback.
TWELVEDATA_API_KEY=

# Get a free key at https://site.financialmodelingprep.com. Uses the new
# "stable" API (https://financialmodelingprep.com/stable/) -- quote,
# batch-quote, search-symbol, profile, historical-price-eod, news.
# REST-only -- FMP's WebSocket streaming is a paid-plan feature, so
# quotes are always marked delayed, never real-time.
FMP_API_KEY=

# Get a free key at https://www.alphavantage.co/support/#api-key (no
# credit card). Genuinely free but capped at ~25 requests/day -- wired in
# as the very last-resort fallback rung, not a primary source.
ALPHAVANTAGE_API_KEY=

# Polygon.io (rebranded "Massive"). RESEARCHED: as of this writing Polygon
# has NO free tier at all -- a paid plan is required for any endpoint.
# Recognized as a config slot for when/if that changes; setting this key
# alone does not unlock any data (see src/providers/polygon.provider.ts).
POLYGON_API_KEY=

# StockerAPI / Kun Data (kun.pro) is a PAID product. No free tier exists.
# Only set these if you have purchased access.
STOCKERAPI_TOKEN=
STOCKERAPI_BASE_URL=https://api.kun.pro

# Get a free key at https://evds2.tcmb.gov.tr (Turkish Central Bank EVDS,
# official, no cost, no card). Unlocks the daily official USD/EUR/GBP/
# JPY/CHF-TRY reference rate as a last-resort forex fallback -- see
# src/providers/tcmb-evds.provider.ts.
EVDS_API_KEY=

# BiQuote (biquote.io): public, unauthenticated REST feed backed by a
# generic MT5 broker connection. RESEARCHED: no company name/ToS found
# (only a support@ email), so this stays OFF by default. It is never
# used for BIST (bigpara/isyatirim already cover that; BiQuote only has
# 6 fixed BIST symbols anyway) -- forex only, and only if you explicitly
# opt in. See src/providers/biquote.provider.ts.
BIQUOTE_ENABLED=false
BIQUOTE_REST_URL=https://biquote.io

# TradingView's public Screener/Scanner backend (scanner.tradingview.com),
# used ONLY for bulk BIST scanner/table data (never single-symbol quotes,
# never depth/AKD/takas/theoretical price -- see
# src/providers/tradingview-scanner.provider.ts). Independent from
# ENABLE_TRADINGVIEW so it can be tested/disabled on its own; protected by
# the same circuit breaker as every other provider, so a sustained block
# (e.g. Render's shared IPs getting the same Cloudflare treatment as the
# tradingview-twc socket) disables it automatically after 3 failures.
ENABLE_TRADINGVIEW_SCANNER=true

# --- Feature flags (all default to enabled; set to "false" to disable) ---
# Master switch: if false, no WebSocket connections are attempted at all
# and every quote comes from the REST fallback chain. Useful for a
# minimal-footprint deploy or isolating a REST-only issue.
ENABLE_STARTUP_STREAMS=true
# TradingView is an unofficial, reverse-engineered socket that can be
# blocked outright by Cloudflare on shared cloud-hosting IP ranges
# (confirmed HTTP 451 on Render). ENABLE_TRADINGVIEW=false disables it
# everywhere (REST getQuote too); ENABLE_TRADINGVIEW_STREAMS=false keeps
# the REST fallback path but skips the persistent WS subscription.
ENABLE_TRADINGVIEW=true
ENABLE_TRADINGVIEW_STREAMS=true
ENABLE_BINANCE_STREAMS=true
ENABLE_BINANCE_FUTURES_STREAMS=true

# --- Backend ---
PORT=4000
REDIS_URL=redis://localhost:6379

# --- Telegram Bot (for Alarm push notifications) ---
TELEGRAM_BOT_TOKEN=

# Optional: enables the LLM rephrasing pass in /api/ai/ask. Without this,
# the AI assistant still works fully via rule-based Turkish intent
# routing over live data -- this key only makes answers more conversational.
ANTHROPIC_API_KEY=

# Optional: set once a licensed BIST L2 data vendor (VERDA/Foreks/Matriks)
# is integrated. Until then, Derinlik/AKD/Teorik Fiyat/Takas honestly
# report "licensed_data_required" -- see src/providers/bist-institutional.provider.ts.
BIST_L2_VENDOR=

# --- Frontend ---
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:4000
NEXT_PUBLIC_BACKEND_HTTP_URL=http://localhost:4000
# Kill switch for the developer diagnostics panel -- see frontend/.env.local.example
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=false
